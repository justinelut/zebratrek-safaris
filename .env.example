# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://user:password@127.0.0.1:5432/zebratrek

# ─── Payload ───────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-key-min-32-chars-here

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=https://zebratrek.com

# ─── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=ZebraTrek Safaris <hello@zebratrek.com>
TEAM_EMAIL=team@zebratrek.com

# ─── Google Analytics & Tag Manager ────────────────────────
# Get GA ID from https://analytics.google.com/ (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Get GTM ID from https://tagmanager.google.com/ (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# ─── Search Engine Verification ────────────────────────────
# Google Search Console: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools: https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ─── S3 Storage (production media) ─────────────────────────
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=
