# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://user:password@127.0.0.1:5432/zebratrek

# ─── Payload ───────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-key-min-32-chars-here

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=https://zebratreksafaris.com

# ─── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=ZebraTrek Safaris <hello@zebratreksafaris.com>
TEAM_EMAIL=team@zebratreksafaris.com

# ─── Google Analytics & Tag Manager ────────────────────────
NEXT_PUBLIC_GA_ID=                          # G-XXXXXXXXXX from GA4
NEXT_PUBLIC_GTM_ID=                         # GTM-XXXXXXX from GTM (optional)

# ─── Search Engine Verification ────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=       # token from Search Console HTML tag method
NEXT_PUBLIC_BING_SITE_VERIFICATION=         # optional, from Bing Webmaster

# ─── S3 Storage (production media) ─────────────────────────
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=
